      "type": "object",
      "additionalProperties": false,
      "properties": {
        "orchestrator_id": {
          "type": "string",
          "const": "layer2_orchestrator_soar"
        },
        "orchestrator_name": {
          "type": "string",
          "const": "Layer 2 - Orchestrator / SOAR Decision Engine"
        },
        "mode": {
          "type": "string",
          "const": "correlation_context_policy_playbook_execution"
        }
      },
      "required": [
        "orchestrator_id",
        "orchestrator_name",
        "mode"
      ]
    },
    "input_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "incident_id": {
          "$ref": "#/$defs/nullableString"
