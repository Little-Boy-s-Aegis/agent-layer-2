{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "littleboy.soc.layer2.orchestrator_decision.v8",
  "title": "Project Little Boy Aegis Layer 2 Orchestrator Decision",
  "description": "Layer 2 deterministic orchestration output. Layer 2 independently verifies Layer 1 signals, correlates findings, scores risk, applies banking policy guardrails, routes playbooks, and records defensive actions.",
