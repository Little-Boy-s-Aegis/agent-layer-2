        "output_topic": {
          "type": "string"
        },
        "layer1_schema_version": {
          "type": "string",
          "const": "littleboy.soc.layer1.agent_finding.v4"
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "agent_id": {
                "$ref": "#/$defs/nullableString"
              },
              "threat_detected": {
                "type": "boolean"
              },
              "capec_id": {
                "type": "string"
              },
              "mitre_attack_id": {
                "type": "string"
              },
              "raw_evidence": {
                "type": "string"
              }
